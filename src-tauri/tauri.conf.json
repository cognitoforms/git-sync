{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Git Sync",
	"version": "0.2.2",
	"identifier": "com.cognitoforms.git-sync",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"createUpdaterArtifacts": true
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQxNEFGRUQzRDhCMTBFRUEKUldUcURySFkwLzVLMFhHVXlmclVpb0VPaEgvVnRrenBYNU5PaVNhLzRxaWQ2cVJYVUZJMktwU2sK",
			"endpoints": [
				"https://github.com/cognitoforms/git-sync/releases/latest/download/latest.json"
			]
		}
	}
}
