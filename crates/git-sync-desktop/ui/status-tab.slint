import { Button, VerticalBox, HorizontalBox, GroupBox } from "std-widgets.slint";
import { DesktopConfig, SyncStatus } from "config-types.slint";

export component StatusTab inherits VerticalBox {
    padding: 20px;
    spacing: 14px;

    in property <string> sync-state-label: "Loading…";
    in property <string> repo-state-label: "Unknown";
    in property <string> last-sync-label: "Never";
    in property <SyncStatus> sync-status: SyncStatus.Unknown;
    in property <string> error-message: "";
    in property <DesktopConfig> config;

    callback sync-now();

    property <color> state-color:
        root.sync-status == SyncStatus.Syncing  ? #2196F3 :
        root.sync-status == SyncStatus.Equal    ? #4CAF50 :
        root.sync-status == SyncStatus.Ahead    ? #FF9800 :
        root.sync-status == SyncStatus.Behind   ? #FF9800 :
        root.sync-status == SyncStatus.Diverged ? #F44336 :
        root.sync-status == SyncStatus.Error    ? #F44336 :
                                                  #9E9E9E;

    GroupBox {
        title: "Repository";

        VerticalBox {
            spacing: 8px;

            HorizontalBox {
                spacing: 8px;
                Text {
                    text: "Path:";
                    font-size: 12px;
                    color: #666666;
                    min-width: 100px;
                    vertical-alignment: center;
                }
                Text {
                    text: root.config.repo-path == ""
                        ? "Not configured — open Settings to set a repository path"
                        : root.config.repo-path;
                    font-size: 12px;
                    color: root.config.repo-path == "" ? #999999 : #222222;
                    overflow: elide;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
            }

            HorizontalBox {
                spacing: 8px;
                Text {
                    text: "State:";
                    font-size: 12px;
                    color: #666666;
                    min-width: 100px;
                    vertical-alignment: center;
                }
                Text {
                    text: root.repo-state-label;
                    font-size: 12px;
                    vertical-alignment: center;
                }
            }
        }
    }

    GroupBox {
        title: "Sync";

        VerticalBox {
            spacing: 12px;

            HorizontalBox {
                spacing: 10px;

                Rectangle {
                    width: 12px;
                    height: 12px;
                    border-radius: 6px;
                    background: root.state-color;
                    vertical-stretch: 0;
                }

                Text {
                    text: root.sync-status == SyncStatus.Syncing ? "Sync in progress…" : root.sync-state-label;
                    font-size: 13px;
                    font-weight: 600;
                    vertical-alignment: center;
                }
            }

            HorizontalBox {
                spacing: 8px;
                Text {
                    text: "Last sync:";
                    font-size: 12px;
                    color: #666666;
                    min-width: 100px;
                    vertical-alignment: center;
                }
                Text {
                    text: root.last-sync-label;
                    font-size: 12px;
                    vertical-alignment: center;
                }
            }

            if root.error-message != "": Rectangle {
                background: #fff5f5;
                border-color: #ffb3b3;
                border-width: 1px;
                border-radius: 4px;

                HorizontalBox {
                    padding: 8px;
                    Text {
                        text: root.error-message;
                        font-size: 12px;
                        color: #cc2222;
                        wrap: word-wrap;
                    }
                }
            }
        }
    }

    Button {
        text: root.sync-status == SyncStatus.Syncing ? "Syncing…" : "Sync Now";
        enabled: root.sync-status != SyncStatus.Syncing && root.config.repo-path != "";
        clicked => { root.sync-now(); }
    }

    Rectangle { vertical-stretch: 1; }
}
