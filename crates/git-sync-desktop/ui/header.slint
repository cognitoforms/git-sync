import { HorizontalBox } from "std-widgets.slint";
import { SyncStatus } from "config-types.slint";

export component HeaderBar inherits Rectangle {
    height: 52px;
    background: #1e1e2e;

    in property <string> sync-state-label: "Loading…";
    in property <SyncStatus> sync-status: SyncStatus.Unknown;

    property <color> state-color:
        root.sync-status == SyncStatus.Syncing  ? #2196F3 :
        root.sync-status == SyncStatus.Equal    ? #4CAF50 :
        root.sync-status == SyncStatus.Ahead    ? #FF9800 :
        root.sync-status == SyncStatus.Behind   ? #FF9800 :
        root.sync-status == SyncStatus.Diverged ? #F44336 :
        root.sync-status == SyncStatus.Error    ? #F44336 :
                                                  #9E9E9E;

    HorizontalBox {
        padding-left: 20px;
        padding-right: 20px;
        spacing: 10px;

        Text {
            text: "git-sync";
            font-size: 18px;
            font-weight: 700;
            color: #cdd6f4;
            vertical-alignment: center;
        }

        Rectangle { horizontal-stretch: 1; }

        Rectangle {
            width: 10px;
            height: 10px;
            border-radius: 5px;
            background: root.state-color;
            vertical-stretch: 0;
        }

        Text {
            text: root.sync-status == SyncStatus.Syncing ? "Syncing…" : root.sync-state-label;
            font-size: 12px;
            color: #a6adc8;
            vertical-alignment: center;
        }
    }
}
