export struct DesktopConfig {
    repo-path: string,
    remote: string,
    branch: string,
    interval: int,
    sync-new-files: bool,
    skip-hooks: bool,
    conflict-branch: bool,
    commit-message: string,
}

export enum SyncStatus {
    Unknown,
    Syncing,
    Equal,
    Ahead,
    Behind,
    Diverged,
    Error,
    NoUpstream,
}
