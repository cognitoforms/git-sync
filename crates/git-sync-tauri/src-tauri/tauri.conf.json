{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Git Sync",
  "version": "0.1.0",
  "identifier": "com.cognitoforms.git-sync",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Git Sync",
        "width": 680,
        "height": 520,
        "minWidth": 520,
        "minHeight": 440,
        "decorations": false,
        "shadow": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
